<Window x:Class="MRTW.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MRTW.App"
        Title="MRTW - Malware Runtime Timeline Workbench"
        Height="940"
        Width="1660"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:SeverityBrushConverter x:Key="SeverityBrush" />
        <local:CategoryBrushConverter x:Key="CategoryBrush" />
        <local:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibility" />
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource AppBg}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Open Target..." Click="OpenTarget_Click" IsEnabled="{Binding CanChangeRunConfiguration}" />
                <MenuItem Header="Open Case..." Click="OpenCase_Click" IsEnabled="{Binding CanChangeRunConfiguration}" />
                <Separator />
                <MenuItem Header="Export Case..." Click="Export_Click" IsEnabled="{Binding CanChangeRunConfiguration}" />
                <Separator />
                <MenuItem Header="Exit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="Start" Click="Start_Click" IsEnabled="{Binding CanStart}" />
                <MenuItem Header="Stop" Click="Stop_Click" IsEnabled="{Binding CanStop}" />
                <MenuItem Header="Restart" Click="Restart_Click" IsEnabled="{Binding CanStop}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Recent Cases..." Click="RecentCases_Click" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Profile Settings..." Click="ProfileSettings_Click" IsEnabled="{Binding CanChangeRunConfiguration}" />
                <MenuItem Header="Export Options..." Click="Settings_Click" IsEnabled="{Binding CanChangeRunConfiguration}" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="34" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#050C14" BorderBrush="#17263A" BorderThickness="0,0,0,1">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="MRTW" FontSize="30" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Grid.Column="1" Text="Malware Runtime Timeline Workbench" Foreground="#C5D2E4" Margin="24,0,0,0" VerticalAlignment="Center" FontSize="15" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Target:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding SelectedTargetDisplay}" Width="360" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Profile:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="16,0,8,0" />
                        <ComboBox Width="150" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" ToolTip="{Binding SelectedProfile.Description}" IsEnabled="{Binding CanChangeRunConfiguration}">
                            <ComboBox.Resources>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Foreground" Value="#111827" />
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#111827" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox Content="Privacy (no raw ETL)" IsChecked="{Binding PrivacyMode}" Margin="12,0,0,0" VerticalAlignment="Center" IsEnabled="{Binding CanChangeRunConfiguration}"/>
                        <TextBlock Text="Export:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="16,0,8,0" />
                        <ComboBox Width="170" ItemsSource="{Binding DllExportCandidates}" Text="{Binding SelectedDllExport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" IsEnabled="{Binding CanChangeRunConfiguration}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#0A1420" BorderBrush="#203149" BorderThickness="0,0,0,1">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sample:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Grid.Column="1" Text="{Binding CurrentCase.SampleName}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Text="MD5:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding StaticAnalysis.Md5}" Foreground="#B8C6D8" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="4" Text="Analysis Profile:" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Grid.Column="5" Text="{Binding SelectedProfile.DisplayName}" Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="6" Style="{StaticResource PrimaryButton}" Content="Start" Click="Start_Click" Width="104" IsEnabled="{Binding CanStart}" />
                    <Button Grid.Column="7" Style="{StaticResource DangerButton}" Content="Stop" Click="Stop_Click" Width="92" IsEnabled="{Binding CanStop}" />
                    <Button Grid.Column="8" Content="Restart" Click="Restart_Click" Width="104" IsEnabled="{Binding CanStop}" />
                    <StackPanel Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="Run Duration" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding RunDuration}" Foreground="{StaticResource AccentBlue}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" MinWidth="230" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" MinWidth="560" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="430" MinWidth="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="240" MinHeight="160" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="*" MinHeight="180" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="250" MinHeight="180" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Panel}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="ANALYSIS STATUS" />
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource Muted}" Text="State" />
                                <TextBlock Text="{Binding StatusText}" Foreground="#66D36E" />
                                <TextBlock Style="{StaticResource Muted}" Text="Target" />
                                <TextBlock Text="{Binding SelectedTargetDisplay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Style="{StaticResource Muted}" Text="Profile" />
                                <TextBlock Text="{Binding SelectedProfile.DisplayName}" Foreground="{StaticResource AccentBlue}" />
                                <TextBlock Style="{StaticResource Muted}" Text="Duration limit" />
                                <TextBlock Text="{Binding AnalysisLimitText}" />
                            </UniformGrid>
                            <TextBlock Style="{StaticResource Muted}" Text="{Binding SelectedProfile.Description}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#203149" />

                    <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="0,0,0,4">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Text="PROCESS TREE" />
                            <TextBlock DockPanel.Dock="Bottom" Text="{Binding ProcessTreeFilterSummary}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,8,0,0" />
                            <ListBox ItemsSource="{Binding CurrentCase.Processes}" SelectedItem="{Binding SelectedProcessNode, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold">
                                                <Run Text="{Binding Name}" />
                                                <Run Text=" (PID " />
                                                <Run Text="{Binding Pid}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" TextTrimming="CharacterEllipsis">
                                                <Run Text="Network " />
                                                <Run Text="{Binding NetworkCount}" />
                                                <Run Text="   Files " />
                                                <Run Text="{Binding FileCount}" />
                                                <Run Text="   Registry " />
                                                <Run Text="{Binding RegistryCount}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#203149" />

                    <Border Grid.Row="4" Style="{StaticResource Panel}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionTitle}" Text="FILTERS" Margin="0" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Reset" Width="72" Padding="8,3" Margin="0" Click="ResetFilters_Click" />
                            </Grid>
                            <TextBlock Style="{StaticResource Muted}" Text="Time Range" />
                            <ComboBox ItemsSource="{Binding TimeRangeOptions}" SelectedItem="{Binding SelectedTimeRange, Mode=TwoWay}" Margin="0,4,0,12">
                                <ComboBox.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#111827" />
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#111827" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Style="{StaticResource Muted}" Text="Process" />
                            <ComboBox ItemsSource="{Binding ProcessFilterOptions}" SelectedItem="{Binding SelectedProcessFilter, Mode=TwoWay}" Margin="0,4,0,12">
                                <ComboBox.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#111827" />
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#111827" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Style="{StaticResource Muted}" Text="Category" Margin="0,0,0,4" />
                            <CheckBox Content="Process" IsChecked="{Binding ShowProcessEvents}" Foreground="#74A2FF" />
                            <CheckBox Content="File" IsChecked="{Binding ShowFileEvents}" Foreground="#78D66E" />
                            <CheckBox Content="Registry" IsChecked="{Binding ShowRegistryEvents}" Foreground="#F0A13C" />
                            <CheckBox Content="Network" IsChecked="{Binding ShowNetworkEvents}" Foreground="#B79DFF" />
                            <CheckBox Content="DNS" IsChecked="{Binding ShowDnsEvents}" Foreground="#5ED7E5" />
                            <CheckBox Content="API" IsChecked="{Binding ShowApiEvents}" Foreground="#E8D46A" />
                            <CheckBox Content="Behavior" IsChecked="{Binding ShowBehaviorEvents}" Foreground="#FF7BD5" />
                            <Separator Background="#26384F" Margin="0,8" />
                            <CheckBox Content="Show noisy API events" IsChecked="{Binding ShowNoiseEvents}" Foreground="{StaticResource TextPrimary}" />
                            <TextBlock Text="{Binding NoiseSummary}" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#203149" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="260" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="220" MinHeight="150" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Panel}" Padding="0">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="92" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TIMELINE" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Grid.Column="1" Text="{Binding FilteredEvents.Count, StringFormat=({0} events)}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="8,0" />
                                <Grid Grid.Column="2">
                                    <TextBox x:Name="TimelineSearchBox" Text="{Binding TimelineSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Search timeline..." Foreground="{StaticResource TextSecondary}" Margin="9,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="{Binding TimelineSearchText, Converter={StaticResource EmptyStringToVisibility}}" />
                                </Grid>
                                <Button Grid.Column="3" Content="Filter" Padding="8,4" Click="Filter_Click" />
                            </Grid>
                            <DataGrid x:Name="TimelineGrid" ItemsSource="{Binding FilteredEvents}" SelectedItem="{Binding SelectedEvent}" Margin="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="112" />
                                    <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="130" />
                                    <DataGridTextColumn Header="Process GUID" Binding="{Binding ProcessGuid}" Width="180" />
                                    <DataGridTemplateColumn Header="Category" Width="96">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Category, Converter={StaticResource CategoryBrush}}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Category}" FontSize="12" Foreground="{StaticResource TextPrimary}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="130" />
                                    <DataGridTextColumn Header="Object" Binding="{Binding ObjectValue}" Width="250" />
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="220" />
                                    <DataGridTextColumn Header="Technique" Binding="{Binding TechniqueId}" Width="92" />
                                    <DataGridTemplateColumn Header="Severity" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="9" Height="9" Fill="{Binding Severity, Converter={StaticResource SeverityBrush}}" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding Severity}" Foreground="{StaticResource TextPrimary}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#203149" />

                    <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="0" Margin="0,4,0,0">
                        <TabControl>
                            <TabItem Header="Artifacts">
                                <DataGrid ItemsSource="{Binding CurrentCase.Artifacts}"
                                          ClipboardCopyMode="IncludeHeader"
                                          SelectionUnit="CellOrRowHeader"
                                          SelectionMode="Extended">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="170" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="80" />
                                        <DataGridTemplateColumn Header="Top Artifacts" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Value}"
                                                             IsReadOnly="True"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Padding="0"
                                                             TextWrapping="NoWrap"
                                                             ToolTip="{Binding Value}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Latest Time" Binding="{Binding LastSeen}" Width="160" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Network">
                                <DataGrid ItemsSource="{Binding NetworkArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Endpoint" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Related Processes" Binding="{Binding RelatedProcesses}" Width="180" />
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="110" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Files">
                                <DataGrid ItemsSource="{Binding FileArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Top Files" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Latest Time" Binding="{Binding LastSeen}" Width="160" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Registry">
                                <DataGrid ItemsSource="{Binding RegistryArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Top Registry Items" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Latest Time" Binding="{Binding LastSeen}" Width="160" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Processes">
                                <DataGrid ItemsSource="{Binding ProcessArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Process Artifact" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Latest Time" Binding="{Binding LastSeen}" Width="160" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Commands">
                                <DataGrid ItemsSource="{Binding CommandArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Command" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Related Processes" Binding="{Binding RelatedProcesses}" Width="180" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="DNS">
                                <DataGrid ItemsSource="{Binding DnsArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Query" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Related Processes" Binding="{Binding RelatedProcesses}" Width="180" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Modules">
                                <DataGrid ItemsSource="{Binding ModuleArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Module" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Related Processes" Binding="{Binding RelatedProcesses}" Width="180" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Credential APIs">
                                <DataGrid ItemsSource="{Binding CredentialApiArtifacts}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="API/Object" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding EventCount}" Width="90" />
                                        <DataGridTextColumn Header="Related Processes" Binding="{Binding RelatedProcesses}" Width="180" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Static Analysis">
                                <TabControl>
                                    <TabItem Header="Summary">
                                        <ScrollViewer><StackPanel Margin="12">
                                            <UniformGrid Columns="2">
                                                <TextBlock Style="{StaticResource Muted}" Text="File"/><TextBlock Text="{Binding StaticAnalysis.FileName}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Full path"/><TextBlock Text="{Binding StaticAnalysis.FullPath}" TextWrapping="Wrap"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Type / Architecture"/><TextBlock><Run Text="{Binding StaticAnalysis.FileType}"/><Run Text=" / "/><Run Text="{Binding StaticAnalysis.Architecture}"/></TextBlock>
                                                <TextBlock Style="{StaticResource Muted}" Text="Size"/><TextBlock Text="{Binding StaticAnalysis.FileSize}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="MD5"/><TextBox Text="{Binding StaticAnalysis.Md5}" IsReadOnly="True"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="SHA-1"/><TextBox Text="{Binding StaticAnalysis.Sha1}" IsReadOnly="True"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="SHA-256"/><TextBox Text="{Binding StaticAnalysis.Sha256}" IsReadOnly="True"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Entry point"/><TextBlock Text="{Binding StaticAnalysis.EntryPoint}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Subsystem"/><TextBlock Text="{Binding StaticAnalysis.Subsystem}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Image base"/><TextBlock Text="{Binding StaticAnalysis.ImageBase}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="PE timestamp"/><TextBlock Text="{Binding StaticAnalysis.PeTimestamp}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Signature"/><TextBlock Text="{Binding StaticAnalysis.SignatureStatus}" TextWrapping="Wrap"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Signature present"/><TextBlock Text="{Binding StaticAnalysis.HasDigitalSignature}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text=".NET image"/><TextBlock Text="{Binding StaticAnalysis.IsDotNet}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Signer"/><TextBlock Text="{Binding StaticAnalysis.SignatureSubject}" TextWrapping="Wrap"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Imphash"/><TextBox Text="{Binding StaticAnalysis.Imphash}" IsReadOnly="True"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Rich header SHA-256"/><TextBox Text="{Binding StaticAnalysis.RichHeaderHash}" IsReadOnly="True"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="Overlay bytes"/><TextBlock Text="{Binding StaticAnalysis.OverlaySize}"/>
                                                <TextBlock Style="{StaticResource Muted}" Text="PDB"/><TextBlock Text="{Binding StaticAnalysis.PdbPath}" TextWrapping="Wrap"/>
                                            </UniformGrid>
                                        </StackPanel></ScrollViewer>
                                    </TabItem>
                                    <TabItem Header="Imports"><ListBox ItemsSource="{Binding StaticAnalysis.Imports}" FontFamily="Consolas"/></TabItem>
                                    <TabItem Header="Exports"><ListBox ItemsSource="{Binding StaticAnalysis.Exports}" FontFamily="Consolas"/></TabItem>
                                    <TabItem Header="Sections"><DataGrid ItemsSource="{Binding StaticAnalysis.Sections}"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding Name}"/><DataGridTextColumn Header="RVA" Binding="{Binding VirtualAddress}"/><DataGridTextColumn Header="Virtual Size" Binding="{Binding VirtualSize}"/><DataGridTextColumn Header="Raw Size" Binding="{Binding RawSize}"/><DataGridTextColumn Header="Entropy" Binding="{Binding Entropy}"/><DataGridTextColumn Header="Characteristics" Binding="{Binding Characteristics}"/></DataGrid.Columns></DataGrid></TabItem>
                                    <TabItem Header="Strings"><ListBox ItemsSource="{Binding StaticAnalysis.SuspiciousStrings}" FontFamily="Consolas"/></TabItem>
                                    <TabItem Header="Resources / TLS"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><ListBox ItemsSource="{Binding StaticAnalysis.Resources}"/><ListBox Grid.Column="1" ItemsSource="{Binding StaticAnalysis.TlsCallbacks}" FontFamily="Consolas"/></Grid></TabItem>
                                    <TabItem Header="Metadata"><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><DataGrid ItemsSource="{Binding StaticAnalysis.VersionInfo}" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="Version field" Binding="{Binding Key}" Width="180"/><DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/></DataGrid.Columns></DataGrid><ListBox Grid.Row="1" ItemsSource="{Binding StaticAnalysis.DotNetMetadata}"/><TextBox Grid.Row="2" Text="{Binding StaticAnalysis.Manifest}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas"/></Grid></TabItem>
                                    <TabItem Header="Indicators"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><ListBox ItemsSource="{Binding StaticAnalysis.PackerIndicators}"/><DataGrid Grid.Column="1" ItemsSource="{Binding StaticAnalysis.EmbeddedPeFiles}"/></Grid></TabItem>
                                </TabControl>
                            </TabItem>
                            <TabItem Header="API Raw">
                                <TextBox Text="{Binding SelectedEvent.RawJson}" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" />
                            </TabItem>
                            <TabItem Header="Report">
                                <Grid Margin="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource Panel}" Grid.Column="0" Margin="4"><StackPanel><TextBlock Text="{Binding CurrentCase.Processes.Count}" Style="{StaticResource MetricValue}" /><TextBlock Text="Processes" /></StackPanel></Border>
                                    <Border Style="{StaticResource Panel}" Grid.Column="1" Margin="4"><StackPanel><TextBlock Text="{Binding DnsEventCount}" Style="{StaticResource MetricValue}" /><TextBlock Text="DNS Queries" /></StackPanel></Border>
                                    <Border Style="{StaticResource Panel}" Grid.Column="2" Margin="4"><StackPanel><TextBlock Text="{Binding NetworkEventCount}" Style="{StaticResource MetricValue}" /><TextBlock Text="Network Events" /></StackPanel></Border>
                                    <Border Style="{StaticResource Panel}" Grid.Column="3" Margin="4"><StackPanel><TextBlock Text="{Binding FileEventCount}" Style="{StaticResource MetricValue}" /><TextBlock Text="Files Written" /></StackPanel></Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#203149" />

                <Grid Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="260" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="300" MinHeight="180" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Panel}" Margin="0,0,0,4">
                        <ScrollViewer>
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="EVENT DETAILS" Style="{StaticResource SectionTitle}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedEvent.Id, StringFormat=ID: {0}}" Foreground="{StaticResource TextSecondary}" />
                                </DockPanel>
                                <TextBlock Text="{Binding SelectedEvent.Action}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextPrimary}" />
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource Muted}" Text="Time" />
                                    <TextBlock Text="{Binding SelectedEvent.Time}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Category" />
                                    <TextBlock Text="{Binding SelectedEvent.Category}" Foreground="{StaticResource AccentBlue}" />
                                <TextBlock Style="{StaticResource Muted}" Text="Severity" />
                                <TextBlock Text="{Binding SelectedEvent.Severity}" Foreground="{Binding SelectedEvent.Severity, Converter={StaticResource SeverityBrush}}" />
                                <TextBlock Style="{StaticResource Muted}" Text="Technique" />
                                <TextBlock Text="{Binding SelectedEvent.TechniqueId}" Foreground="{StaticResource AccentBlue}" />
                                <TextBlock Style="{StaticResource Muted}" Text="Source" />
                                <TextBlock Text="{Binding SelectedEvent.Source}" />
                            </UniformGrid>
                                <Separator Background="#26384F" />
                                <TextBlock Text="SUMMARY" FontWeight="Bold" Margin="0,12,0,5" />
                                <TextBlock Text="{Binding SelectedEvent.Summary}" TextWrapping="Wrap" />
                                <TextBlock Text="PROCESS" FontWeight="Bold" Margin="0,16,0,5" />
                                <UniformGrid Columns="2">
                                    <TextBlock Style="{StaticResource Muted}" Text="Name" />
                                    <TextBlock Text="{Binding SelectedEvent.Process}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="PID" />
                                    <TextBlock Text="{Binding SelectedEvent.Pid}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Process GUID" />
                                    <TextBlock Text="{Binding SelectedEvent.ProcessGuid}" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Object" />
                                    <TextBlock Text="{Binding SelectedEvent.ObjectValue}" TextWrapping="Wrap" />
                                </UniformGrid>
                                <TextBlock Text="EVIDENCE / RELATED EVENTS" FontWeight="Bold" Margin="0,16,0,5" />
                                <TextBlock Text="{Binding EvidenceSummary}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <DataGrid ItemsSource="{Binding RelatedEvidenceEvents}"
                                          MaxHeight="180"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="44" />
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90" />
                                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="130" />
                                        <DataGridTextColumn Header="Object" Binding="{Binding ObjectValue}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Text="RAW EVENT (JSON)" FontWeight="Bold" Margin="0,16,0,5" />
                                <TextBox Text="{Binding SelectedEvent.RawJson}" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" MinHeight="180" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#203149" />

                    <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="CASE INSIGHTS" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding AnalysisSummary}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,14" />
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource Muted}" Text="Events" />
                                    <TextBlock Text="{Binding CurrentCase.Events.Count}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Processes" />
                                    <TextBlock Text="{Binding CurrentCase.Processes.Count}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="High findings" />
                                    <TextBlock Text="{Binding CurrentCase.HighCount}" Foreground="{StaticResource AccentRed}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Network events" />
                                    <TextBlock Text="{Binding NetworkEventCount}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="File events" />
                                    <TextBlock Text="{Binding FileEventCount}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Registry events" />
                                    <TextBlock Text="{Binding RegistryEventCount}" />
                                    <TextBlock Style="{StaticResource Muted}" Text="Collection quality" />
                                    <TextBlock Text="{Binding CollectionQualityStatus}" Foreground="{StaticResource AccentBlue}" />
                                </UniformGrid>
                                <TextBlock Text="{Binding CollectionQualitySummary}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8" />
                                <Separator Background="#26384F" Margin="0,12" />
                                <TextBlock Text="NOTES" FontWeight="Bold" Margin="0,0,0,5" />
                                <TextBlock Text="{Binding CurrentCase.AnalystNotes}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="3" Background="#0A1420" BorderBrush="#203149" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusText}" Foreground="#66D36E" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding CurrentCase.Events.Count, StringFormat=Events: {0}}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding CurrentCase.Processes.Count, StringFormat=Processes: {0}}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding RunDuration, StringFormat=Runtime: {0}}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="{Binding SelectedProfile.DisplayName, StringFormat=Profile: {0}}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="5" Text="{Binding SamplePath}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="6" Text="{Binding AnalysisLimitText, StringFormat=Limit: {0}}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
