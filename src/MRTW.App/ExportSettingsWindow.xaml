<Window x:Class="MRTW.App.ExportSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Options"
        Width="460"
        Height="520"
        MinWidth="420"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Background="{StaticResource AppBg}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="EXPORT OPTIONS" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="Choose the artifacts and formats used by File > Export Case." Foreground="{StaticResource TextSecondary}" Margin="0,6,0,16" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Formats" FontWeight="Bold" Margin="0,0,0,8" />
                <CheckBox Content="HTML Report" IsChecked="{Binding HtmlReport}" />
                <CheckBox Content="CSV Timeline" IsChecked="{Binding CsvTimeline}" />
                <CheckBox Content="CSV Artifacts" IsChecked="{Binding CsvArtifacts}" />
                <CheckBox Content="JSON Case" IsChecked="{Binding JsonCase}" />
                <CheckBox Content="JSONL Raw Events" IsChecked="{Binding JsonlRawEvents}" />
                <CheckBox Content="SQLite Bundle" IsChecked="{Binding SqliteBundle}" />

                <Separator Background="#26384F" Margin="0,16" />

                <TextBlock Text="Contents" FontWeight="Bold" Margin="0,0,0,8" />
                <CheckBox Content="Include Raw Event Data" IsChecked="{Binding IncludeRaw}" />
                <CheckBox Content="Include Sample File" IsChecked="{Binding IncludeSample}" />
                <CheckBox Content="Compress Output" IsChecked="{Binding CompressOutput}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Width="96" Click="Cancel_Click" />
            <Button Content="Save" Width="96" Style="{StaticResource PrimaryButton}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
